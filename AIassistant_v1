<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>AI Drive Assistant - SAKURA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body, html { height: 100%; margin: 0; background-color: #0f172a; color: #f8fafc; overflow: hidden; font-family: 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif; touch-action: manipulation; }
        
        /* 電光掲示板のスタイル */
        .led-board {
            background-color: #000;
            border: 8px solid #1e293b;
            border-radius: 16px;
            box-shadow: inset 0 0 30px rgba(0,0,0,0.9), 0 10px 20px rgba(0,0,0,0.5);
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        /* 網目模様（LEDのドット感） */
        .led-board::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: radial-gradient(rgba(0,0,0,0.5) 1px, transparent 1px);
            background-size: 4px 4px;
            pointer-events: none;
            z-index: 10;
        }

        /* テキストのスタイル（オレンジネオン） */
        .led-text {
            color: #fb923c;
            text-shadow: 0 0 5px #fb923c, 0 0 15px #ea580c, 0 0 30px #c2410c;
            font-family: 'Courier New', monospace;
            font-weight: 900;
            white-space: nowrap;
        }

        /* モード：顔文字（中央固定） */
        .mode-kaomoji {
            font-size: 5rem;
            transform: translateY(-5px);
        }

        /* モード：スクロール（右から左へ） */
        .mode-scroll {
            font-size: 3rem;
            position: absolute;
            left: 100%;
            animation: scroll-left linear forwards;
        }

        @keyframes scroll-left {
            0% { transform: translateX(0); }
            100% { transform: translateX(-100%); left: 0; }
        }

        /* マイク録音中のアニメーション */
        @keyframes pulse-ring {
            0% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.6); }
            70% { box-shadow: 0 0 0 20px rgba(6, 182, 212, 0); }
            100% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0); }
        }
        .mic-active { animation: pulse-ring 1.5s infinite; border-color: #22d3ee !important; }

        /* モーダル */
        .modal { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.9); z-index: 999; flex-direction: column; }
        .modal.active { display: flex; }
        
        .toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: rgba(6, 182, 212, 0.9); color: white; padding: 12px 24px; border-radius: 12px; z-index: 1000; display: none; font-weight: bold; }
    </style>
</head>
<body class="flex flex-col h-full p-4 gap-4 relative">

    <audio id="ai-audio-player" playsinline></audio>

    <!-- ヘッダー -->
    <header class="flex justify-between items-center shrink-0">
        <div>
            <h1 class="text-xl font-black text-cyan-400 italic tracking-wider text-shadow-sm">DRIVE ASSIST <span class="text-white">AI</span></h1>
            <p id="address-display" class="text-xs text-slate-400 font-bold truncate w-48">現在地を検索中...</p>
        </div>
        <div class="flex gap-3">
            <button id="btn-logs" class="bg-slate-800 p-3 rounded-full text-cyan-400 border border-slate-700 active:bg-slate-700 shadow-lg"><i data-lucide="message-square"></i></button>
            <button id="btn-settings" class="bg-slate-800 p-3 rounded-full text-slate-300 border border-slate-700 active:bg-slate-700 shadow-lg"><i data-lucide="settings"></i></button>
        </div>
    </header>

    <!-- 電光掲示板エリア（メイン） -->
    <div class="led-board flex-grow w-full my-2 relative">
        <!-- デフォルトは顔文字モード -->
        <div id="led-display" class="led-text mode-kaomoji">( ˘ω˘ )</div>
    </div>

    <!-- ステータス表示 -->
    <div class="flex justify-between items-end shrink-0 px-2">
        <div class="flex flex-col gap-1">
            <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">GPS Status</span>
            <div id="gps-status" class="text-xs font-black text-cyan-400 flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span> ONLINE</div>
        </div>
        <div class="flex flex-col items-end gap-1">
            <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">AI State</span>
            <div id="ai-status" class="text-xs font-black text-slate-300">待機中</div>
        </div>
    </div>

    <!-- AIアイコン 兼 マイクボタン -->
    <div class="flex justify-center items-center shrink-0 pb-6 pt-2">
        <div id="mic-btn" class="relative cursor-pointer transition-transform active:scale-95">
            <div class="w-24 h-24 rounded-full border-4 border-cyan-700 overflow-hidden shadow-[0_0_20px_rgba(6,182,212,0.3)] bg-slate-800 flex items-center justify-center transition-all duration-300" id="avatar-ring">
                <img src="sakura_icon.png" alt="さくら" onerror="this.src='https://via.placeholder.com/128/0f172a/06b6d4?text=Sakura'" class="w-full h-full object-cover opacity-90">
            </div>
            <!-- マイクアイコンバッジ -->
            <div class="absolute -bottom-2 -right-2 bg-cyan-500 border-4 border-[#0f172a] rounded-full p-2 text-slate-900">
                <i data-lucide="mic" class="w-5 h-5"></i>
            </div>
        </div>
    </div>

    <!-- 過去ログ モーダル -->
    <div id="modal-logs" class="modal p-4">
        <header class="flex justify-between items-center mb-4">
            <h2 class="text-lg font-black text-cyan-400">会話ログ</h2>
            <button class="close-modal p-2 text-slate-400"><i data-lucide="x"></i></button>
        </header>
        <div id="log-container" class="flex-grow overflow-y-auto bg-slate-800 rounded-xl border border-slate-700 p-4 flex flex-col gap-3">
            <p class="text-center text-slate-500 text-sm mt-10">まだログがないで！</p>
        </div>
    </div>

    <!-- 設定 モーダル -->
    <div id="modal-settings" class="modal p-4">
        <header class="flex justify-between items-center mb-4">
            <h2 class="text-lg font-black text-slate-200">設定</h2>
            <button class="close-modal p-2 text-slate-400"><i data-lucide="x"></i></button>
        </header>
        <div class="flex-grow overflow-y-auto flex flex-col gap-4">
            <div class="bg-slate-800 p-5 rounded-xl border border-slate-700">
                <h3 class="text-xs font-bold text-cyan-400 uppercase mb-3">Gemini API キー</h3>
                <input type="password" id="api-key-input" placeholder="AIza..." class="w-full bg-slate-900 border border-slate-600 rounded-lg px-3 py-3 text-sm text-white mb-3 focus:outline-none focus:border-cyan-500">
                <button id="save-key-btn" class="w-full bg-cyan-600 text-slate-900 font-black py-3 rounded-lg active:bg-cyan-500">保存して接続テスト</button>
                <div id="api-status-msg" class="text-xs mt-3 text-center font-bold"></div>
            </div>

            <div class="bg-slate-800 p-5 rounded-xl border border-slate-700">
                <h3 class="text-xs font-bold text-cyan-400 uppercase mb-3">音声設定</h3>
                <div class="flex items-center justify-between border-b border-slate-700 pb-4 mb-4">
                    <div>
                        <p class="font-bold text-sm text-slate-200">超リアルボイス <span class="text-[10px] bg-cyan-900 text-cyan-300 px-1.5 py-0.5 rounded ml-1">Beta</span></p>
                        <p class="text-[10px] text-slate-400 mt-1">人間みたいな声やけどAPIを2回消費するで</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" id="real-voice-toggle" class="sr-only peer">
                        <div class="w-11 h-6 bg-slate-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-cyan-500"></div>
                    </label>
                </div>
                <div class="flex items-center gap-4">
                    <i data-lucide="volume-2" class="text-slate-400"></i>
                    <input type="range" id="volume-slider" min="0" max="100" class="w-full accent-cyan-500">
                </div>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <script type="module">
        // APIキーと設定の読み込み
        let apiKey = localStorage.getItem('GEMINI_API_KEY') || "";
        let useRealVoice = localStorage.getItem('useRealVoice') === 'true';
        let voiceVolume = parseFloat(localStorage.getItem('voiceVolume')) || 1.0;
        
        let chatHistory = []; // ゆーくんとの会話の文脈を覚える配列
        let actionLogs = [];  // 画面に表示する過去ログ用配列
        
        let isAIThinking = false;
        let isSpeechRecognizing = false;
        let audioUnlocked = false;
        
        // GPS系変数
        let currentPos = null;
        let currentHeading = 0;
        let lastPosForHeading = null;
        let lastAddress = "検索中...";
        let lastAddressFetchTime = 0;
        
        // 周辺情報系変数
        let POI_LIST = []; // Points of Interest (観光地・飲食店・オービスなど)
        let lastPoiFetchTime = 0;
        let notifiedPois = new Set(); // 既に通知した場所のIDを記憶

        // --- UI操作系 ---
        function showToast(msg) {
            const t = document.getElementById('toast');
            t.textContent = msg; t.style.display = 'block';
            setTimeout(() => { t.style.display = 'none'; }, 3000);
        }

        function setAIStatus(text, isRecording = false) {
            document.getElementById('ai-status').textContent = text;
            const ring = document.getElementById('avatar-ring');
            if (isRecording) {
                ring.classList.add('mic-active');
            } else {
                ring.classList.remove('mic-active');
            }
        }

        // --- 電光掲示板の制御 ---
        function updateSignboard(text, kaomoji, mode) {
            const board = document.getElementById('led-display');
            
            // アニメーションのリセット
            board.style.animation = 'none';
            board.offsetHeight; // リフローを強制

            if (mode === 'chat') {
                board.className = 'led-text mode-kaomoji';
                board.textContent = kaomoji || '(^_^)';
            } else if (mode === 'info') {
                board.className = 'led-text mode-scroll';
                board.textContent = text;
                // 文字数に応じてスクロール速度を調整（1文字約0.25秒）
                const duration = Math.max(8, text.length * 0.25);
                board.style.animation = `scroll-left ${duration}s linear forwards`;
                
                // スクロールが終わったら顔文字に戻す
                setTimeout(() => {
                    if (board.textContent === text) {
                        board.className = 'led-text mode-kaomoji';
                        board.textContent = kaomoji || '( ˘ω˘ )';
                    }
                }, duration * 1000);
            }
        }

        // --- ログの記録と表示 ---
        function addLog(role, text) {
            actionLogs.push({ role, text, time: new Date() });
            const container = document.getElementById('log-container');
            
            if (actionLogs.length === 1) container.innerHTML = ''; // 初期メッセージ削除
            
            const div = document.createElement('div');
            const isUser = role === 'user';
            div.className = `flex flex-col ${isUser ? 'items-end' : 'items-start'}`;
            
            const name = isUser ? 'ゆーくん' : 'さくら';
            const color = isUser ? 'bg-slate-700 text-slate-200' : 'bg-cyan-900/50 border border-cyan-800 text-cyan-100';
            
            div.innerHTML = `
                <span class="text-[10px] text-slate-500 mb-1">${name} - ${new Date().toLocaleTimeString('ja-JP', {hour:'2-digit', minute:'2-digit'})}</span>
                <div class="${color} px-4 py-2 rounded-2xl max-w-[85%] text-sm font-bold shadow-sm">
                    ${text}
                </div>
            `;
            container.appendChild(div);
            // 最新のログへスクロール
            container.scrollTop = container.scrollHeight;
        }

        // --- オーディオ関連 ---
        function unlockAudio() {
            if (audioUnlocked) return;
            const player = document.getElementById('ai-audio-player');
            if(player) { player.src = "data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAAABkYXRhAgAAAAEA"; player.play().catch(()=>{}); }
            if ('speechSynthesis' in window) { const u = new SpeechSynthesisUtterance(''); u.volume = 0; window.speechSynthesis.speak(u); }
            audioUnlocked = true;
        }

        function playAudioPCM(base64) {
            const bin = atob(base64), bytes = new Uint8Array(bin.length);
            for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
            const sr = 24000, hdr = new ArrayBuffer(44), v = new DataView(hdr);
            v.setUint32(0, 0x52494646, false); v.setUint32(4, 36 + bin.length, true); v.setUint32(8, 0x57415645, false);
            v.setUint32(12, 0x666d7420, false); v.setUint32(16, 16, true); v.setUint16(20, 1, true);
            v.setUint16(22, 1, true); v.setUint32(24, sr, true); v.setUint32(28, sr * 2, true);
            v.setUint16(32, 2, true); v.setUint16(34, 16, true); v.setUint32(36, 0x64617461, false); v.setUint32(40, bin.length, true);
            const player = document.getElementById('ai-audio-player');
            if(player) { 
                player.src = URL.createObjectURL(new Blob([new Uint8Array([...new Uint8Array(hdr), ...bytes])], { type: 'audio/wav' })); 
                player.volume = voiceVolume; 
                player.play(); 
            }
        }

        async function speak(text) {
            if (useRealVoice && apiKey) {
                try {
                    const resp = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
                        method: 'POST', headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            contents: [{ parts: [{ text: `Say cheerfully: ${text}` }] }],
                            generationConfig: { responseModalities: ["AUDIO"], speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Kore" } } } }
                        })
                    });
                    if (resp.ok) {
                        const data = await resp.json();
                        const pcm = data.candidates?.[0]?.content?.parts?.[0]?.inlineData?.data;
                        if (pcm) { playAudioPCM(pcm); return; }
                    }
                } catch(e) { console.warn("リアルボイス失敗、標準に切替", e); }
            }
            // フォールバック（標準音声）
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel();
                const u = new SpeechSynthesisUtterance(text);
                u.lang = 'ja-JP'; u.volume = voiceVolume; u.pitch = 1.2; u.rate = 1.1;
                window.speechSynthesis.speak(u);
            }
        }

        // --- Gemini AI 通信 ---
        async function askSakura(prompt, isAutoPush = false) {
            if (!apiKey) { showToast("設定からAPIキーを登録してな！"); return; }
            if (isAIThinking) return;
            
            isAIThinking = true;
            if (!isAutoPush) {
                setAIStatus('考え中...');
                addLog('user', prompt);
                chatHistory.push({ role: "user", parts: [{ text: prompt }] });
            }

            // 直近のPOIリスト（最大5件）をAIに教える
            const nearbyStr = POI_LIST.slice(0,5).map(p => `[${p.type}] ${p.name} (距離: ${Math.round(p.distance)}m)`).join(", ");

            const sysInstruction = `
あなたは神戸弁の明るい女子学生AI「さくら」です。ユーザー「ゆーくん」の車の助手席でナビサポートをしています。
現在地: ${lastAddress}
周辺情報: ${nearbyStr || "特になし"}

【指示】
ユーザーの問いかけに答え、過去の会話の文脈も考慮してください。
周辺のラーメン屋や観光地を聞かれたら、「周辺情報」を元に答えてください。
出力は必ず以下のJSONスキーマに従うこと。Markdownのコードブロック等の装飾は付けないでください。

{
  "type": "chat", // 挨拶や日常会話なら "chat"、周辺情報や道案内を答えるなら "info"
  "text": "ゆーくんへの返答テキスト（神戸弁でフレンドリーに）",
  "kaomoji": "今の感情の顔文字 (例: (*´ω｀*), ( ﾟДﾟ), (T_T) )"
}`;

            try {
                const reqBody = {
                    contents: chatHistory,
                    systemInstruction: { parts: [{ text: sysInstruction }] },
                    tools: [{ "google_search": {} }],
                    generationConfig: { responseMimeType: "application/json" }
                };

                const resp = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(reqBody)
                });
                
                if (!resp.ok) throw new Error("API_ERR");
                
                const data = await resp.json();
                const rawText = data.candidates?.[0]?.content?.parts?.[0]?.text;
                
                if (rawText) {
                    try {
                        const parsed = JSON.parse(rawText);
                        // AIの記憶にはテキストだけ保存する
                        chatHistory.push({ role: "model", parts: [{ text: parsed.text }] });
                        if (chatHistory.length > 20) chatHistory = chatHistory.slice(-20); // 記憶の制限

                        addLog('model', parsed.text);
                        speak(parsed.text);
                        
                        // 掲示板の更新（chatなら顔文字のみ、infoならテキストスクロール）
                        updateSignboard(parsed.text, parsed.kaomoji, parsed.type);
                        
                    } catch (parseErr) {
                        console.error("JSONパースエラー", rawText);
                        // JSON失敗時のフォールバック
                        chatHistory.push({ role: "model", parts: [{ text: rawText }] });
                        addLog('model', rawText);
                        speak(rawText);
                        updateSignboard(rawText, "(^_^)", "info");
                    }
                }
            } catch (err) {
                console.error(err);
                if (!isAutoPush) chatHistory.pop(); // エラー時はユーザーの質問を消す
                showToast("通信エラーやわ…APIキーとか確認してな！");
            } finally {
                isAIThinking = false;
                setAIStatus('待機中');
            }
        }

        // --- GPS・周辺情報の取得 ---
        function getDistance(la1, lo1, la2, lo2) {
            const R = 6371000, dLa = (la2-la1)*Math.PI/180, dLo = (lo2-lo1)*Math.PI/180;
            const a = Math.sin(dLa/2)**2 + Math.cos(la1*Math.PI/180)*Math.cos(la2*Math.PI/180)*Math.sin(dLo/2)**2;
            return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        }

        function getBearing(lat1, lng1, lat2, lng2) {
            const toRad = Math.PI / 180, toDeg = 180 / Math.PI;
            const dLng = (lng2 - lng1) * toRad;
            const y = Math.sin(dLng) * Math.cos(lat2 * toRad);
            const x = Math.cos(lat1 * toRad) * Math.sin(lat2 * toRad) - Math.sin(lat1 * toRad) * Math.cos(lat2 * toRad) * Math.cos(dLng);
            return (Math.atan2(y, x) * toDeg + 360) % 360;
        }

        async function fetchNearbyPOI(lat, lng) {
            if (Date.now() - lastPoiFetchTime < 180000) return; // 3分に1回
            lastPoiFetchTime = Date.now();
            try {
                // 飲食店、観光地、オービスをまとめて取得 (半径3km)
                const q = `[out:json];(
                    node["highway"="speed_camera"](around:3000,${lat},${lng});
                    nwr["amenity"~"restaurant|cafe|fast_food"](around:3000,${lat},${lng});
                    nwr["tourism"~"museum|viewpoint|attraction"](around:3000,${lat},${lng});
                );out center;`;
                
                const resp = await fetch(`https://overpass-api.de/api/interpreter?data=${encodeURIComponent(q)}`);
                const data = await resp.json();
                
                if (data.elements) {
                    POI_LIST = data.elements.map(el => {
                        const clat = el.lat || el.center?.lat;
                        const clng = el.lon || el.center?.lon;
                        if (!clat || !clng || !el.tags) return null;
                        
                        let type = "unknown";
                        let name = el.tags.name || "名称不明";
                        
                        if (el.tags.highway === "speed_camera") { type = "オービス"; name = el.tags.name || "固定式オービス"; }
                        else if (el.tags.amenity) type = "飲食店";
                        else if (el.tags.tourism) type = "観光地";
                        
                        return { id: el.id, lat: clat, lng: clng, type, name, tags: el.tags, distance: 0 };
                    }).filter(Boolean);
                }
            } catch (e) { console.error("POI Fetch Error", e); }
        }

        async function updateAddress(lat, lng) {
            if (Date.now() - lastAddressFetchTime < 60000) return; // 1分に1回
            lastAddressFetchTime = Date.now();
            try {
                const resp = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}&zoom=18`, { headers: { 'Accept-Language': 'ja' } });
                const data = await resp.json();
                if (data && data.address) {
                    const a = data.address;
                    const newAddr = [a.province||a.state, a.city||a.town||a.village, a.suburb||a.neighbourhood, a.road].filter(Boolean).join('');
                    
                    if (lastAddress !== newAddr) {
                        lastAddress = newAddr;
                        document.getElementById('address-display').textContent = lastAddress;
                        // 住所が変わったらプッシュ通知
                        if (apiKey) {
                            addLog('model', `現在地更新: ${lastAddress}`);
                            updateSignboard(`[現在地] ${lastAddress} を走行中やで！`, '( ˘ω˘ )', 'info');
                        }
                    }
                }
            } catch (e) {}
        }

        function checkSurroundings(lat, lng) {
            if (!POI_LIST.length || isAIThinking) return;
            
            // 距離を計算して近い順にソート
            POI_LIST.forEach(poi => { poi.distance = getDistance(lat, lng, poi.lat, poi.lng); });
            POI_LIST.sort((a, b) => a.distance - b.distance);

            // 進行方向にあるオービスチェック (1km以内)
            const nearbyOrbis = POI_LIST.find(p => p.type === "オービス" && p.distance < 1000 && !notifiedPois.has(p.id));
            if (nearbyOrbis) {
                const bearing = getBearing(lat, lng, nearbyOrbis.lat, nearbyOrbis.lng);
                let angleDiff = bearing - currentHeading;
                angleDiff = (angleDiff + 180) % 360 - 180;
                if (Math.abs(angleDiff) <= 60 || currentHeading === 0) {
                    notifiedPois.add(nearbyOrbis.id);
                    const msg = `⚠️注意⚠️ この先、${Math.round(nearbyOrbis.distance)}m付近にオービスがあるで！速度落としてな！`;
                    addLog('model', msg);
                    speak(msg);
                    updateSignboard(msg, '( ﾟДﾟ)', 'info');
                    return; // 警告優先
                }
            }
            
            // ついでに観光地やお店の自動案内（300m以内でまだ言ってない場所）
            // ※頻繁に喋りすぎないように、一度言ったら覚える
            const nearbySpot = POI_LIST.find(p => (p.type === "観光地" || p.type === "飲食店") && p.distance < 300 && !notifiedPois.has(p.id) && p.name !== "名称不明");
            if (nearbySpot && Math.random() > 0.5) { // 50%の確率で紹介する（うるさすぎ防止）
                notifiedPois.add(nearbySpot.id);
                // AIに一言考えさせる
                askSakura(`今、${nearbySpot.name}(${nearbySpot.type})の近くを通ってるから、一言で紹介して！`, true);
            }
        }

        function updateLocation(pos) {
            const { latitude: lat, longitude: lng, heading } = pos.coords;
            document.getElementById('gps-status').innerHTML = `<span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span> ONLINE`;
            
            if (heading !== null && !isNaN(heading)) {
                currentHeading = heading;
            } else if (lastPosForHeading) {
                const d = getDistance(lastPosForHeading.lat, lastPosForHeading.lng, lat, lng);
                if (d > 2) currentHeading = getBearing(lastPosForHeading.lat, lastPosForHeading.lng, lat, lng);
            }
            lastPosForHeading = {lat, lng};
            currentPos = [lat, lng];

            updateAddress(lat, lng);
            fetchNearbyPOI(lat, lng).then(() => checkSurroundings(lat, lng));
        }

        // --- イベントリスナー ---
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();

            // モーダル操作
            document.getElementById('btn-logs').onclick = () => document.getElementById('modal-logs').classList.add('active');
            document.getElementById('btn-settings').onclick = () => {
                document.getElementById('api-key-input').value = apiKey;
                document.getElementById('real-voice-toggle').checked = useRealVoice;
                document.getElementById('volume-slider').value = voiceVolume * 100;
                document.getElementById('modal-settings').classList.add('active');
            };
            document.querySelectorAll('.close-modal').forEach(btn => {
                btn.onclick = (e) => e.target.closest('.modal').classList.remove('active');
            });

            // 設定保存
            document.getElementById('save-key-btn').onclick = () => {
                apiKey = document.getElementById('api-key-input').value.trim();
                localStorage.setItem('GEMINI_API_KEY', apiKey);
                document.getElementById('api-status-msg').textContent = "キーを保存したで！";
                document.getElementById('api-status-msg').className = "text-xs mt-3 text-center font-bold text-cyan-400";
            };
            document.getElementById('real-voice-toggle').onchange = (e) => {
                useRealVoice = e.target.checked;
                localStorage.setItem('useRealVoice', useRealVoice);
            };
            document.getElementById('volume-slider').oninput = (e) => {
                voiceVolume = e.target.value / 100;
                localStorage.setItem('voiceVolume', voiceVolume);
            };

            // マイク操作
            const sr = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (sr) {
                const rec = new sr(); rec.lang = 'ja-JP';
                rec.onstart = () => { isSpeechRecognizing = true; setAIStatus('聞いてるで！', true); };
                rec.onend = () => { isSpeechRecognizing = false; if(!isAIThinking) setAIStatus('待機中'); };
                rec.onerror = () => { isSpeechRecognizing = false; if(!isAIThinking) setAIStatus('待機中'); };
                rec.onresult = (e) => askSakura(e.results[0][0].transcript);

                const micBtn = document.getElementById('mic-btn');
                const handleMic = (e) => {
                    if (e) e.preventDefault();
                    if (!apiKey) { showToast("まずは設定からAPIキーを入れてな！"); return; }
                    if (isSpeechRecognizing) { try{rec.stop();}catch(err){} return; }
                    unlockAudio();
                    try { rec.start(); } catch(err) {}
                };
                micBtn.addEventListener('click', (e) => { if (e.pointerType === "touch") return; handleMic(e); });
                micBtn.addEventListener('touchend', handleMic);
            }

            // GPS開始
            if ("geolocation" in navigator) {
                navigator.geolocation.watchPosition(updateLocation, (err) => {
                    document.getElementById('gps-status').innerHTML = `<span class="w-2 h-2 rounded-full bg-red-500"></span> ERROR`;
                }, { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 });
            }
        });
    </script>
</body>
</html>
